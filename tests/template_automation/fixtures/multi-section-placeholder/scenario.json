{
  "fixture_id": "multi-section-placeholder",
  "category": "multi-section template",
  "description": "Only the intended section should be updated.",
  "scenarios": [
    {
      "id": "replace-only-second-section",
      "description": "Section-scoped token replacement updates the target section and leaves the other section alone.",
      "operation": {
        "type": "token_replace",
        "scopes": ["body"],
        "search": "{{SEC1}}",
        "replacement": "SEC10001",
        "section_indexes": [1]
      },
      "assertions": {
        "expected_replacements": 1,
        "page_guard_pass": true,
        "metric_fields_unchanged": [
          "section_count",
          "paragraph_count",
          "table_count"
        ],
        "section_contains": [
          {"section_index": 0, "value": "{{SEC0}}"},
          {"section_index": 1, "value": "SEC10001"}
        ],
        "section_absent": [
          {"section_index": 1, "value": "{{SEC1}}"}
        ]
      }
    }
  ]
}
